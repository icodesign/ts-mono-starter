{
  "name": "@workspace/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#components/community": "./src/components/community",
    "#components/community/*": "./src/components/community/*",
    "#components/custom": "./src/components/custom",
    "#components/custom/*": "./src/components/custom/*",
    "#components/*": "./src/components/*.tsx",
    "#lib": "./src/lib",
    "#lib/*": "./src/lib/*.ts",
    "#styles/*": "./src/styles/*.css"
  },
  "exports": {
    ".": "./src/index.ts",
    "./globals.css": "./src/styles/globals.css",
    "./lib/*": "./src/lib/*.ts",
    "./components/community/better-auth-ui/*": "./src/components/community/better-auth-ui/*.tsx",
    "./components/*": "./src/components/*.tsx",
    "./components/community/kumo": "./src/components/community/kumo/index.tsx",
    "./components/community/kumo/*": "./src/components/community/kumo/*.tsx",
    "./components/community/shadcn/*": "./src/components/community/shadcn/*.tsx",
    "./components/custom/*": "./src/components/custom/*.tsx"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "shadcn": "bun scripts/shadcn.ts shadcn",
    "shadcn:add": "bun scripts/shadcn.ts shadcn add",
    "shadcn:docs": "bun scripts/shadcn.ts shadcn docs --base base",
    "shadcn:info": "bun scripts/shadcn.ts shadcn info"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@better-auth-ui/core": "^1.6.8",
    "@better-auth-ui/react": "^1.6.8",
    "@cloudflare/kumo": "^2.2.0",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-pacer": "^0.22.1",
    "@tanstack/react-query": "^5.100.10",
    "better-auth": "^1.6.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.16.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^10.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "typescript": "catalog:"
  }
}
