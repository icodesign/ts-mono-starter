{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "changeme-web",
  "main": "server/index.ts",
  "compatibility_date": "2026-05-14",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "CLERK_PUBLISHABLE_KEY": "",
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
  },
}
