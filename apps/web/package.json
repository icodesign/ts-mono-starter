{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run sync:studio-assets && vp dev",
    "build": "bun run sync:studio-assets && bun run cf-typegen && vp build && tsc -p tsconfig.json --noEmit",
    "preview": "vp preview",
    "deploy": "bun run build && wrangler deploy",
    "typecheck": "bun run cf-typegen && tsc -p tsconfig.json --noEmit",
    "cf-typegen": "wrangler types --env-file .env.example",
    "sync:studio-assets": "bun run ./scripts/sync-studio-assets.ts",
    "auth:schema": "bunx auth@latest generate --config ./server/auth/auth.config.ts --output ../../packages/database/src/auth-schema.ts --yes"
  },
  "dependencies": {
    "@better-auth-ui/core": "^1.6.8",
    "@better-auth/drizzle-adapter": "^1.6.11",
    "@better-auth/infra": "^0.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/react-start": "^1.167.65",
    "@workspace/database": "workspace:*",
    "@workspace/ui": "workspace:*",
    "better-auth": "^1.6.11",
    "better-auth-studio": "^1.1.3-beta.49",
    "drizzle-orm": "catalog:",
    "hono": "^4.10.7",
    "mime": "^4.1.0",
    "next-themes": "^0.4.6",
    "react": "catalog:",
    "react-dom": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.37.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "catalog:build",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "catalog:build",
    "vite": "catalog:build",
    "vite-plus": "catalog:build",
    "wrangler": "catalog:build"
  }
}
