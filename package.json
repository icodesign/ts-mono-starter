{
  "name": "cozydevs",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*",
    "modules/agentrun/packages/*",
    "modules/agentrun/packages/adapters/agents/*",
    "modules/agentrun/packages/adapters/sandboxes/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "biome:check": "biome check .",
    "auth:schema": "bun run --cwd apps/web auth:schema",
    "infra:dev:up": "docker compose -f infra/dev/docker-compose.yml up -d",
    "infra:dev:down": "docker compose -f infra/dev/docker-compose.yml down",
    "infra:dev:logs": "docker compose -f infra/dev/docker-compose.yml logs -f"
  },
  "catalog": {
    "@types/node": "^25.0.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3",
    "wrangler": "^4.91.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "turbo": "^2.9.12"
  }
}
