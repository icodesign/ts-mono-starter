{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "types": ["node", "react", "react-dom"],
    "paths": {
      "#components/community": ["./src/components/community"],
      "#components/community/*": ["./src/components/community/*"],
      "#components/custom": ["./src/components/custom"],
      "#components/custom/*": ["./src/components/custom/*"],
      "#components/*": ["./src/components/*.tsx"],
      "#lib": ["./src/lib"],
      "#lib/*": ["./src/lib/*.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "components/**/*.tsx", "scripts/**/*.ts"]
}
